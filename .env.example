APP_NAME=Lima Learning
ENVIRONMENT=development
PORT=8080
DATABASE_PATH=./data/lima_learning.db
WORKER_POLL_SECONDS=15
AUTO_STEP_LIMIT_PER_TICK=1

# Manager backend: rules or llm
MANAGER_BACKEND=rules
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60

# Executor backend: mock or http
EXECUTOR_BACKEND=mock
ARISTOTLE_BASE_URL=
ARISTOTLE_API_KEY=

PUBLIC_BASE_URL=
LOG_LEVEL=INFO
