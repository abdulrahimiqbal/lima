APP_NAME=Lima Learning
ENVIRONMENT=development
PORT=8080
MEMORY_DB_PATH=./data/lima_memory.db
# Optional for Railway/Postgres
MEMORY_DATABASE_URL=
WORKER_POLL_SECONDS=15
AUTO_STEP_LIMIT_PER_TICK=1

# Manager backend: rules or llm
MANAGER_BACKEND=rules
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60

# Executor backend: mock or aristotle (legacy alias: http)
EXECUTOR_BACKEND=mock
ARISTOTLE_BASE_URL=
ARISTOTLE_API_KEY=
ARISTOTLE_TIMEOUT_SECONDS=120
STRICT_LIVE_ARISTOTLE=false

ENABLE_SELF_IMPROVEMENT=false
PUBLIC_BASE_URL=
LOG_LEVEL=INFO
OPERATOR_API_KEY=
