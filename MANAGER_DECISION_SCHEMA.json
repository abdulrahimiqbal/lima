{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ManagerDecision",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "candidate_answer",
        "alternatives",
        "target_frontier_node",
        "world_family",
        "bounded_claim",
        "formal_obligations",
        "expected_information_gain",
        "why_this_next",
        "update_rules",
        "self_improvement_note",
        "manager_read_receipt"
    ],
    "properties": {
        "candidate_answer": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "stance",
                "summary",
                "confidence"
            ],
            "properties": {
                "stance": {
                    "type": "string",
                    "enum": [
                        "likely_true",
                        "likely_false",
                        "undecided"
                    ]
                },
                "summary": {
                    "type": "string",
                    "minLength": 1
                },
                "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                }
            }
        },
        "alternatives": {
            "type": "array",
            "maxItems": 2,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "summary",
                    "confidence"
                ],
                "properties": {
                    "summary": {
                        "type": "string",
                        "minLength": 1
                    },
                    "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                    }
                }
            }
        },
        "target_frontier_node": {
            "type": "string",
            "minLength": 1
        },
        "world_family": {
            "type": "string",
            "enum": [
                "direct",
                "bridge",
                "reformulate",
                "finite_check",
                "counterexample",
                "local_to_global",
                "invariant_lift",
                "structural_case_split"
            ]
        },
        "bounded_claim": {
            "type": "string",
            "minLength": 1
        },
        "formal_obligations": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {
                "oneOf": [
                    {
                        "type": "string",
                        "minLength": 1
                    },
                    {
                        "type": "object",
                        "properties": {
                            "id": {"type": ["string", "null"]},
                            "source_text": {"type": "string", "minLength": 1},
                            "channel_hint": {"type": "string", "enum": ["proof", "evidence", "auto"]},
                            "goal_kind": {"type": "string", "enum": ["lemma", "theorem", "sanity_check", "finite_check", "counterexample_search", "reduction_check"]},
                            "theorem_name": {"type": ["string", "null"]},
                            "imports": {"type": "array", "items": {"type": "string"}},
                            "variables": {"type": "array", "items": {"type": "string"}},
                            "assumptions": {"type": "array", "items": {"type": "string"}},
                            "statement": {"type": ["string", "null"]},
                            "lean_declaration": {"type": ["string", "null"]},
                            "bounded_domain_description": {"type": ["string", "null"]},
                            "evidence_plan": {"type": "object"},
                            "tactic_hints": {"type": "array", "items": {"type": "string"}},
                            "requires_proof": {"type": "boolean"},
                            "requires_evidence": {"type": "boolean"},
                            "metadata": {"type": "object"}
                        },
                        "required": ["source_text"]
                    }
                ]
            }
        },
        "expected_information_gain": {
            "type": "string",
            "minLength": 1
        },
        "why_this_next": {
            "type": "string",
            "minLength": 1
        },
        "update_rules": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "if_proved",
                "if_refuted",
                "if_blocked",
                "if_inconclusive"
            ],
            "properties": {
                "if_proved": {
                    "type": "string",
                    "minLength": 1
                },
                "if_refuted": {
                    "type": "string",
                    "minLength": 1
                },
                "if_blocked": {
                    "type": "string",
                    "minLength": 1
                },
                "if_inconclusive": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "self_improvement_note": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "proposal",
                "reason"
            ],
            "properties": {
                "proposal": {
                    "type": "string"
                },
                "reason": {
                    "type": "string"
                }
            }
        },
        "manager_read_receipt": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "problem_summary",
                "target_node_id_confirmed",
                "target_node_text_confirmed",
                "why_not_other_frontier_nodes"
            ],
            "properties": {
                "problem_summary": {
                    "type": "string",
                    "minLength": 1
                },
                "candidate_answer_seen": {
                    "type": ["string", "null"]
                },
                "target_node_id_confirmed": {
                    "type": "string",
                    "minLength": 1
                },
                "target_node_text_confirmed": {
                    "type": "string",
                    "minLength": 1
                },
                "operator_notes_seen": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "relevant_memory_seen": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "constraints_seen": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "open_uncertainties": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "why_not_other_frontier_nodes": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "obligation_hints": {
            "type": "object",
            "additionalProperties": true
        },
        "global_thesis": {
            "type": ["string", "null"]
        },
        "primary_world": {
            "type": ["object", "null"],
            "properties": {
                "id": {"type": "string"},
                "label": {"type": "string"},
                "family_tags": {"type": "array", "items": {"type": "string"}},
                "mode": {"type": "string", "enum": ["macro", "micro"]},
                "thesis": {"type": "string"},
                "ontology": {"type": "array", "items": {"type": "string"}},
                "compression_principles": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": {"type": "string"},
                            "description": {"type": "string"}
                        }
                    }
                },
                "bridge_to_target": {
                    "type": ["object", "null"],
                    "properties": {
                        "bridge_claim": {"type": "string"},
                        "bridge_obligations": {"type": "array", "items": {"type": "string"}},
                        "estimated_cost": {"type": "number"}
                    }
                },
                "reduction_certificate": {
                    "type": ["object", "null"],
                    "properties": {
                        "closure_items": {"type": "array", "items": {"type": "string"}},
                        "bridge_items": {"type": "array", "items": {"type": "string"}},
                        "support_items": {"type": "array", "items": {"type": "string"}},
                        "total_debt_count": {"type": "number"}
                    }
                },
                "theorem_deltas": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {"type": "string"},
                            "delta_type": {"type": "string"},
                            "source_claim": {"type": "string"},
                            "transformed_claim": {"type": "string"},
                            "distance_from_target": {"type": "number"},
                            "bridge_back_claim": {"type": "string"},
                            "estimated_proof_gain": {"type": "number"},
                            "estimated_bridge_cost": {"type": "number"}
                        }
                    }
                },
                "falsifiers": {"type": "array", "items": {"type": "string"}}
            }
        },
        "alternative_worlds": {
            "type": "array",
            "items": {"$ref": "#/properties/primary_world"}
        },
        "proof_debt": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {"type": "string"},
                    "world_id": {"type": "string"},
                    "role": {"type": "string", "enum": ["closure", "bridge", "support", "boundary", "falsifier"]},
                    "statement": {"type": "string"},
                    "depends_on": {"type": "array", "items": {"type": "string"}},
                    "critical": {"type": "boolean"},
                    "status": {"type": "string", "enum": ["open", "active", "proved", "refuted", "blocked"]},
                    "priority": {"type": "number"},
                    "notes": {"type": "array", "items": {"type": "string"}}
                }
            }
        },
        "critical_next_debt_id": {
            "type": ["string", "null"]
        }
    }
}
