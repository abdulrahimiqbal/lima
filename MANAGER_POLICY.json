{
    "version": "1.1.0",
    "policy_name": "lima-manager-live-policy",
    "description": "Mutable strategy layer for the LIMA manager. Updated to reduce evidence-only loops and encourage proof-oriented escalation.",
    "decision_biases": {
        "prefer_small_formal_moves": true,
        "prefer_high_information_gain": true,
        "prefer_information_gain_per_cost": true,
        "prefer_falsifiable_claims": true,
        "prefer_bridge_lemmas_when_direct_stalls": true,
        "prefer_counterexample_search_when_confidence_is_low": true,
        "force_local_sanity_checks_before_global_claims": true,
        "forbid_global_universal_obligations_as_default": true,
        "separate_proof_and_computation_channels": true,
        "force_claim_shrinking_after_timeout": true,
        "penalize_rebundled_large_jobs": true,
        "penalize_repeated_inconclusive_large_claims": true,
        "penalize_retry_after_hard_refutation": true,
        "escalate_evidence_to_proof_after_streak": true,
        "prefer_formalization_over_repeated_evidence": true
    },
    "complexity_limits": {
        "max_primary_claims_per_cycle": 1,
        "max_formal_obligations_per_cycle": 4,
        "max_proof_obligations_per_step": 1,
        "max_evidence_jobs_per_step": 2,
        "max_new_frontier_nodes_per_cycle": 3,
        "max_alternative_candidate_answers": 2,
        "max_retry_count_same_pattern": 2,
        "default_claim_size": "small",
        "evidence_only_streak_threshold": 3,
        "formalization_failure_streak_threshold": 2,
        "timeout_streak_threshold": 2
    },
    "world_family_priors": {
        "direct": 0.35,
        "bridge": 0.85,
        "reformulate": 0.65,
        "finite_check": 0.55,
        "counterexample": 0.55,
        "local_to_global": 0.60,
        "invariant_lift": 0.45,
        "structural_case_split": 0.50
    },
    "theorem_delta_priors": {
        "strengthen_hypothesis": 0.70,
        "weaken_conclusion": 0.65,
        "change_measure": 0.60,
        "introduce_normal_form": 0.75,
        "factor_through_intermediate": 0.80,
        "minimal_counterexample": 0.55,
        "residue_refinement": 0.70,
        "classify_then_transfer": 0.65,
        "bounded_to_schema": 0.75,
        "shortcut_dynamics": 0.60
    },
    "bridge_cost_penalty": 0.15,
    "proximity_bonus": 0.20,
    "debt_burn_down_reward": 0.25,
    "failure_penalties": {
        "bad_world": 0.30,
        "false_bridge": 0.45,
        "missing_lemma": 0.10,
        "excessive_scope": 0.25,
        "mixed_channels": 0.22,
        "timeout": 0.20,
        "rebundled_large_jobs": 0.24,
        "poor_formalization": 0.08,
        "counterexample_found": 0.60,
        "inconclusive_probe": 0.12,
        "evidence_only": 0.05,
        "formalization_failed": 0.15,
        "proof_failed": 0.10
    },
    "success_rewards": {
        "verified_local_lemma": 0.20,
        "successful_reduction": 0.28,
        "bridge_survives_sanity_check": 0.16,
        "counterexample_refutes_dead_branch": 0.18,
        "frontier_reduction": 0.30
    },
    "blocked_state_rules": {
        "after_two_inconclusive_moves": "shrink_claim",
        "after_hard_refutation": "switch_world_family",
        "after_formalization_failure": "state_clean_formal_claim",
        "after_missing_lemma": "create_child_frontier_node",
        "after_timeout": "shrink_claim_and_reduce_obligation_count",
        "after_excessive_scope": "split_channels_and_localize_claim",
        "after_counterexample_found": "mark_branch_dead",
        "after_two_evidence_only_moves": "synthesize_lemma",
        "after_proof_failed": "split_into_missing_lemma"
    },
    "confidence_rules": {
        "base_confidence_floor": 0.15,
        "base_confidence_ceiling": 0.85,
        "increase_on_successful_reduction": 0.10,
        "increase_on_verified_bridge": 0.12,
        "decrease_on_false_bridge": 0.18,
        "decrease_on_counterexample": 0.35,
        "decrease_on_repeated_inconclusive": 0.08
    },
    "prompt_insertions": {
        "default_style": "Be decisive, compact, and formalization-aware. Always provide formal Lean statements in obligations.",
        "when_confidence_low": "Prefer a move that efficiently breaks the leading hypothesis.",
        "when_confidence_high": "Prefer a move that formalizes the narrowest critical dependency.",
        "when_blocked": "Shrink scope or switch worlds explicitly. Do not narrate around the blockage.",
        "after_evidence_streak": "When repeated bounded evidence has not improved the frontier, convert the best evidence pattern into a formal local lemma with explicit Lean statement.",
        "after_formalization_failure": "State the claim in clean Lean-compatible form with explicit types, quantifiers, and assumptions. Provide the 'statement' field with valid Lean syntax.",
        "after_proof_failure": "Identify the missing lemma or split the theorem into smaller provable pieces. Each piece must have a formal Lean statement.",
        "formalization_requirements": "CRITICAL: Every proof obligation MUST include a 'statement' field with valid Lean syntax (e.g., '∀ n : ℕ, n > 2 → n^2 > 2*n') OR a 'lean_declaration' with complete Lean code. Natural language alone will fail. Include 'tactic_hints' when you have strategic insight. Link obligations to proof debt via 'metadata'."
    },
    "invention_policy": {
        "default_batch_size": 30,
        "default_wildness": "high",
        "strategy_slots": [
            "alien_state_space_encoding",
            "parity_word_grammar",
            "residue_flow_conservation",
            "minimal_counterexample_world",
            "compressed_trajectory_dynamics",
            "inverse_tree_normal_form",
            "rewrite_system_termination",
            "two_adic_shadow_dynamics",
            "automaton_boundary_world",
            "bridge_from_unrelated_field"
        ],
        "truth_boundary": "Inventions may create candidates only; verdicts and solved state require proof debt discharge.",
        "batch_contract": "Every invented world must introduce new objects, a bridge back to target, cheap falsifiers, and proof debt."
    },
    "invention_scoring": {
        "novelty_weight": 0.35,
        "bridge_weight": 0.30,
        "falsifiability_weight": 0.20,
        "formalizability_weight": 0.15,
        "penalize_restatement": 0.35,
        "reward_dead_pattern_avoidance": 0.20
    },
    "falsifier_policy": {
        "falsify_before_aristotle": true,
        "store_negative_patterns": true,
        "collatz_probe_samples": [3, 7, 27, 31, 63, 127],
        "kill_empty_ontology": true,
        "kill_circular_bridge": true
    },
    "retrieval_policy": {
        "include_recent_invention_batches": 5,
        "include_promising_worlds": 10,
        "include_dead_patterns": 20,
        "include_bake_attempts": 20
    },
    "learned_patterns": [],
    "notes": [
        "This file is allowed to evolve over time.",
        "Do not treat this file as constitutional truth.",
        "The manager may propose changes to this file through the self-improvement loop.",
        "Version 1.1.0: Added escalation rules for evidence-only loops and formalization failures."
    ]
}
